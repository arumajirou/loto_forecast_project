# loto_forecast_project local example
# Copy this file to .env and edit locally. Do not commit real secrets.

# PostgreSQL connection
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=loto
DB_PASSWORD=
DB_NAME=loto

# Source dataset is read-only by policy.
DB_SCHEMA=dataset
DB_TABLE=loto_y_ts

# Writable schemas for metadata, model outputs, exogenous features, resources, catalog and logs.
META_SCHEMA=meta
META_TABLE=nf_automodel
MODEL_SCHEMA=model
MODEL_TABLE=nf_automodel
EXOG_SCHEMA=exog
RESOURCES_SCHEMA=resources
CATALOG_SCHEMA=catalog
LOG_SCHEMA=log

# Local SQLite registry used by infra helpers.
LOTO_DB_PATH=./data/registry.sqlite

# Runtime output directories. These are ignored by git.
ARTIFACT_DIR=./artifacts
LOG_DIR=./logs
LOG_LEVEL=INFO

# Time series defaults
FREQ=D
DEFAULT_HORIZON=28
TIME_COL=ds
TARGET_COL=y
ID_COL=unique_id
DEFAULT_LAGS=1,7,14
DEFAULT_WINDOWS=7,14,28

# Codegen catalog input. Set this path only when the file exists locally.
CODEGEN_YAML_PATH=./docs/lib_docs/neuralforecast_all_codegen.yaml
